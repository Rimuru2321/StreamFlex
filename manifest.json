{
  "name": "StreamFlex — 映画",
  "short_name": "StreamFlex",
  "description": "Tu plataforma personal de películas y series",
  "id": "streamflex-app",
  "start_url": "/index.html",
  "scope": "/",
  "display": "standalone",
  "display_override": ["tabbed", "window-controls-overlay", "standalone"],
  "background_color": "#0a0a0a",
  "theme_color": "#cc0000",
  "orientation": "portrait-primary",
  "lang": "es",
  "dir": "ltr",
  "categories": ["entertainment"],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "prefer_related_applications": false,
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "scope_extensions": [],
  "file_handlers": [],
  "protocol_handlers": [
    {
      "protocol": "web+streamflex",
      "url": "/index.html?protocol=%s"
    }
  ],
  "share_target": {
    "action": "/index.html",
    "method": "POST",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "screenshots": [
    {
      "src": "/screenshots/screenshot-wide.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "StreamFlex — Pantalla principal"
    },
    {
      "src": "/screenshots/screenshot-mobile.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "StreamFlex — Inicio de sesión"
    }
  ],
  "icons": [
    { "src": "/icons/icon-72x72.png",            "sizes": "72x72",   "type": "image/png" },
    { "src": "/icons/icon-96x96.png",            "sizes": "96x96",   "type": "image/png" },
    { "src": "/icons/icon-128x128.png",          "sizes": "128x128", "type": "image/png" },
    { "src": "/icons/icon-144x144.png",          "sizes": "144x144", "type": "image/png" },
    { "src": "/icons/icon-152x152.png",          "sizes": "152x152", "type": "image/png" },
    { "src": "/icons/icon-192x192.png",          "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192x192-maskable.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "/icons/icon-384x384.png",          "sizes": "384x384", "type": "image/png" },
    { "src": "/icons/icon-512x512.png",          "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512x512-maskable.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "shortcuts": [
    {
      "name": "Inicio",
      "url": "/index.html",
      "icons": [{ "src": "/icons/icon-96x96.png", "sizes": "96x96", "type": "image/png" }]
    }
  ]
}